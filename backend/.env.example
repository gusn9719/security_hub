# ── Gemini API ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_key_here

# ── Docker 이미지 ──────────────────────────────────────────────────────────────
BROWSERLESS_IMAGE=ghcr.io/browserless/chromium:latest

# ── Cloudflare Tunnel / 리버스 프록시 ─────────────────────────────────────────
# Named Tunnel 사용 시: 외부에서 접근 가능한 HTTPS 도메인 (포트 없이)
# 예) BASE_URL=https://api.your-domain.com
# Quick Tunnel 사용 시: cloudflared 실행 후 출력된 URL로 교체
# 예) BASE_URL=https://xxxx.trycloudflare.com
# 미설정 시 요청의 Host 헤더에서 자동 추론 (로컬 에뮬레이터 개발 시 생략 가능)
BASE_URL=

# X-Forwarded-Proto 헤더 없는 환경에서 HTTPS 강제 (true/false)
# Cloudflare Tunnel은 X-Forwarded-Proto: https 를 자동 주입하므로 보통 불필요
FORCE_HTTPS=false

# 프로덕션 배포 시 /docs /redoc /openapi.json 비활성화 (NF-25)
DISABLE_DOCS=false
